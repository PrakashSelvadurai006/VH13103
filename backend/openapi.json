{
  "openapi": "3.0.0",
  "info": {
    "title": "Campus Notification System API",
    "version": "1.0.0",
    "description": "REST API documentation for the Placement Portal Campus Notification System."
  },
  "servers": [
    {
      "url": "http://localhost:5000/api",
      "description": "Local Development Server"
    }
  ],
  "paths": {
    "/notifications": {
      "get": {
        "summary": "Retrieve paginated notifications feed",
        "description": "Fetches a paginated, sorted list of notifications. Returns cached records from Redis for student-specific queries.",
        "parameters": [
          {
            "name": "studentId",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Filter by student database ID"
          },
          {
            "name": "type",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["Event", "Result", "Placement"]
            },
            "description": "Filter by notification type category"
          },
          {
            "name": "isRead",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            },
            "description": "Filter by read/unread status"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 10
            },
            "description": "Max number of items to return"
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 0
            },
            "description": "Pagination offset"
          },
          {
            "name": "cursor",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "description": "UUID Cursor notification ID for cursor-based pagination"
          }
        ],
        "responses": {
          "200": {
            "description": "A paginated array of notifications",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Notification"
                      }
                    },
                    "meta": {
                      "$ref": "#/components/schemas/PaginationMeta"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create a new single notification",
        "description": "Inserts a notification record into Postgres, invalidates the student's Redis cache, and emits a live Socket.IO update.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["studentId", "type", "message"],
                "properties": {
                  "studentId": {
                    "type": "integer"
                  },
                  "type": {
                    "type": "string",
                    "enum": ["Event", "Result", "Placement"]
                  },
                  "message": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created notification details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "data": {
                      "$ref": "#/components/schemas/Notification"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request or student validation failure"
          }
        }
      }
    },
    "/notifications/{id}": {
      "get": {
        "summary": "Retrieve notification by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Notification details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "data": {
                      "$ref": "#/components/schemas/Notification"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Notification not found"
          }
        }
      },
      "delete": {
        "summary": "Delete a notification",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully deleted notification details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "data": {
                      "$ref": "#/components/schemas/Notification"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Notification not found"
          }
        }
      }
    },
    "/notifications/{id}/read": {
      "patch": {
        "summary": "Toggle notification read status",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "isRead": {
                    "type": "boolean",
                    "default": true
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated notification details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "data": {
                      "$ref": "#/components/schemas/Notification"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Notification not found"
          }
        }
      }
    },
    "/notifications/bulk": {
      "post": {
        "summary": "Enqueue bulk notifications for students",
        "description": "Subdivides the target list into batches of 5000 and dispatches them to Redis queues managed by BullMQ worker instances.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["type", "message"],
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": ["Event", "Result", "Placement"]
                  },
                  "message": {
                    "type": "string"
                  },
                  "studentIds": {
                    "type": "array",
                    "items": {
                      "type": "integer"
                    },
                    "description": "Target students (optional; if empty, sends to all students in database)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Bulk delivery job enqueued",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "success": {
                          "type": "boolean"
                        },
                        "jobsEnqueued": {
                          "type": "integer"
                        },
                        "totalStudentsCount": {
                          "type": "integer"
                        },
                        "message": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/notifications/student/{studentId}/priority": {
      "get": {
        "summary": "Retrieve student priority inbox (Top 10)",
        "description": "Fetches a student's notifications feed, runs priority score calculations, and extracts the top 10 ranked alerts using a Min-Heap queue.",
        "parameters": [
          {
            "name": "studentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Top 10 priority ranked notifications list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "allOf": [
                          {
                            "$ref": "#/components/schemas/Notification"
                          },
                          {
                            "type": "object",
                            "properties": {
                              "score": {
                                "type": "integer",
                                "description": "Calculated priority rank score"
                              }
                            }
                          }
                        ]
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/notifications/optimize/placement-students": {
      "get": {
        "summary": "Fetch students that received placement updates",
        "description": "Uses an optimized PostgreSQL index-driven raw join select statement to pull student listings.",
        "responses": {
          "200": {
            "description": "List of matching student profiles",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "integer"
                          },
                          "name": {
                            "type": "string"
                          },
                          "email": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Notification": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "studentId": {
            "type": "integer"
          },
          "type": {
            "type": "string",
            "enum": ["Event", "Result", "Placement"]
          },
          "message": {
            "type": "string"
          },
          "isRead": {
            "type": "boolean"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "PaginationMeta": {
        "type": "object",
        "properties": {
          "total": {
            "type": "integer"
          },
          "limit": {
            "type": "integer"
          },
          "offset": {
            "type": "integer"
          },
          "cursor": {
            "type": "string",
            "nullable": true
          }
        }
      }
    }
  }
}
